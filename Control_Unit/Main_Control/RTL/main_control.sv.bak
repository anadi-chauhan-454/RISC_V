module main_control(
  input  logic [6:0] opcode,

  output logic       reg_write,
  output logic       alu_src,
  output logic       mem_write,
  output logic       branch,
  output logic       jump,
  output logic [1:0] result_src,
  output logic [1:0] alu_op,
  output logic [2:0] imm_src
);

  always_comb begin
    reg_write  = 0;
    alu_src    = 0;
    mem_write  = 0;
    branch     = 0;
    jump       = 0;
    result_src = 2'b00;
    alu_op     = 2'b00;
    imm_src    = 3'b000;

    case(opcode)

      7'b0110011: begin
        reg_write  = 1;
        alu_src    = 0;
        alu_op     = 2'b10;
      end

      7'b0010011: begin
        reg_write  = 1;
        alu_src    = 1;
        alu_op     = 2'b11;
        imm_src    = 3'b000;
      end

      7'b0000011: begin
        reg_write  = 1;
        alu_src    = 1;
        result_src = 2'b01;
        alu_op     = 2'b00;
        imm_src    = 3'b000;
      end

      7'b0100011: begin
        alu_src    = 1;
        mem_write  = 1;
        alu_op     = 2'b00;
        imm_src    = 3'b001;
      end

      7'b1100011: begin
        branch     = 1;
        alu_op     = 2'b01;
        imm_src    = 3'b010;
      end

      7'b1101111: begin
        reg_write  = 1;
        jump       = 1;
        result_src = 2'b10;
        imm_src    = 3'b100;
      end

      7'b1100111: begin
        reg_write  = 1;
        alu_src    = 1;
        jump       = 1;
        result_src = 2'b10;
        alu_op     = 2'b00;
        imm_src    = 3'b000;
      end

      7'b0110111: begin
        reg_write  = 1;
        imm_src    = 3'b011;
      end

      7'b0010111: begin
        reg_write  = 1;
        alu_src    = 1;
        alu_op     = 2'b00;
        imm_src    = 3'b011;
      end

      default: begin
      end

    endcase
  end

endmodule
